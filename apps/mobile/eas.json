  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://7afefli-api.vercel.app",
        "EXPO_PUBLIC_SUPABASE_URL": "https://phfwutugsyiutqgippqg.supabase.co"
