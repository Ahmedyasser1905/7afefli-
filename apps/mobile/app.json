{
  "expo": {
    "name": "7afefli",
    "slug": "barberdz-monorepo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "hafefli",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ahmedyasser.hafefli",
      "splash": {
        "image": "./assets/splash.png",
        "tabletImage": "./assets/splash.png",
        "backgroundColor": "#050A1A",
        "resizeMode": "contain"
      }
    },
    "android": {
      "package": "com.ahmedyasser.hafefli",
      "adaptiveIcon": {
        "backgroundColor": "#050A1A",
        "foregroundImage": "./assets/splash.png"
      },
      "splash": {
        "backgroundColor": "#050A1A",
        "resizeMode": "contain",
        "ldpi":    "./assets/splash.png",
        "mdpi":    "./assets/splash.png",
        "hdpi":    "./assets/splash.png",
        "xhdpi":   "./assets/splash.png",
        "xxhdpi":  "./assets/splash.png",
        "xxxhdpi": "./assets/splash.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-notifications",
      "expo-splash-screen",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Autoriser 7afefli à accéder à votre position pour trouver les salons les plus proches.",
          "locationAlwaysPermission": "Autoriser 7afefli à accéder à votre position pour trouver les salons les plus proches.",
          "locationWhenInUsePermission": "Autoriser 7afefli à accéder à votre position pour trouver les salons les plus proches."
        }
      ]
    ],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#050A1A"
    },
    "extra": {
      "eas": {
        "projectId": "ab62f7fd-4869-4d66-9274-3a1bfe134de5"
      }
    },
    "owner": "ahmed19052004"
  }
}
