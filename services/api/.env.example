# BarberDZ API — Environment Variables
# Copy this file to .env and fill in real values before running.
# Variables marked [REQUIRED] must be set or the application will refuse to start.
# Variables marked [PROD] are additionally required in NODE_ENV=production.

# ── Supabase ──────────────────────────────────────────────────────────────────
# [REQUIRED] Your project URL (Dashboard → Settings → API)
SUPABASE_URL=https://<your-project>.supabase.co

# [REQUIRED] Service role key — keep secret, never expose in client code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# [REQUIRED] Anon/public key — safe to expose to clients
SUPABASE_ANON_KEY=your-anon-key-here

# ── Auth ──────────────────────────────────────────────────────────────────────
# [REQUIRED] Secret used to sign internal JWTs (min 32 chars, random string)
JWT_SECRET=your-jwt-secret-min-32-chars-here

# ── CORS ──────────────────────────────────────────────────────────────────────
# [REQUIRED] Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Redis (optional in dev, required in prod) ─────────────────────────────────
# [PROD] Redis connection URL for throttling and caching
# REDIS_URL=redis://default:password@redis-host:6379

# ── Sentry (optional in dev, required in prod) ────────────────────────────────
# [PROD] Sentry DSN for error monitoring
# SENTRY_DSN=https://your-key@sentry.io/your-project-id

# ── Payments ──────────────────────────────────────────────────────────────────
# [PROD] Chargily payment gateway secret key
# CHARGILY_SECRET_KEY=your-chargily-secret-key-here

# ── Payment Redirect URLs ─────────────────────────────────────────────────────
# Use deep links for mobile: hafefli://payment/success
# PAYMENT_SUCCESS_URL=https://7afefli.com/payment/success
# PAYMENT_FAILURE_URL=https://7afefli.com/payment/failure
